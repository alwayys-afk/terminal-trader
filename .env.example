# Copy this file to `.env` and fill in your credentials.
# Create an app at https://developer.schwab.com and set the app's
# callback (redirect) URL to exactly: https://127.0.0.1:8182

SCHWAB_API_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Optional: where OAuth tokens are cached (default: schwab_tokens.json)
# SCHWAB_TOKEN_PATH=schwab_tokens.json

# Optional: log verbosity (logs are written to trader.log)
# RUST_LOG=info
